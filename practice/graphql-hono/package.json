{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "graphql-hono",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "server": "tsx watch src/server/app.ts",
        "client": "vite",
        "dev": "pnpm codegen & pnpm server & pnpm client",
        "codegen": "graphql-codegen --config codegen.ts"
    },
    "author": "satin",
    "license": "ISC",
    "description": "graphql + hono practice",
    "dependencies": {
        "@hono/graphql-server": "^0.7.0",

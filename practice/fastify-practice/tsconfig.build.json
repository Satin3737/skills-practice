{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": false,
        "allowImportingTsExtensions": false,
        "rewriteRelativeImportExtensions": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "sourceMap": true,
        "declaration": false,
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "erasableSyntaxOnly": false
    },
    "include": ["src"],
    "exclude": ["node_modules"],
    "tsc-alias": {
        "resolveFullPaths": true
    }
}

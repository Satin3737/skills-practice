generator client {
  provider = "prisma-client"
  output   = "../src/database/prisma"
}

generator prismabox {
  provider = "prismabox"
  output   = "../src/database/prismabox"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  trooper
  captain
  admiral
  emperor
}

enum PlanetType {
  dwarf
  gasGiant
  satellite
  exoplanet
}

model User {
  id             Int          @id @default(autoincrement())
  email          String       @unique
  password       String
  type           UserType     @default(trooper)
  stormtrooper   Stormtrooper @relation(fields: [stormtrooperId], references: [id], onDelete: Cascade)
  stormtrooperId Int          @unique
  sessions       Session[]
}

model Session {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Stormtrooper {
  id       Int       @id @default(autoincrement())
  callSign String
  user     User?
  missions Mission[]
  weapons  Weapon[]
}

model Weapon {
  id           Int            @id @default(autoincrement())
  mark         String
  damage       Int
  isDeadly     Boolean        @default(false)
  stormtrooper Stormtrooper[]
}

model Mission {
  id           Int            @id @default(autoincrement())
  title        String
  briefing     String?
  isCompleted  Boolean        @default(false)
  stormtrooper Stormtrooper[]
  planet       Planet         @relation(fields: [planetId], references: [id], onDelete: Cascade)
  planetId     Int
}

model Planet {
  id       Int        @id @default(autoincrement())
  name     String
  size     Int
  type     PlanetType @default(exoplanet)
  hasRings Boolean    @default(false)
  missions Mission[]
}

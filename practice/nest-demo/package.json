{
    "name": "nest-demo",
    "version": "1.0.0",
    "description": "nest-demo",
    "author": "satin",
    "private": true,
    "license": "ISC",
    "scripts": {
        "dev": "pnpm run start:dev",
        "build": "nest build",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/main",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage"
    },
    "dependencies": {
        "@nestjs/common": "^11.1.27",
        "@nestjs/config": "^4.0.4",
        "@nestjs/core": "^11.1.27",
        "@nestjs/mapped-types": "*",
        "@nestjs/platform-express": "^11.1.27",
        "@nestjs/swagger": "^11.4.5",
        "@nestjs/typeorm": "^11.0.3",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "mysql2": "^3.22.5",
        "rxjs": "^7.8.2",
        "typeorm": "^1.0.0"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.23",
        "@nestjs/schematics": "^11.1.0",
        "@nestjs/testing": "^11.1.27",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/node": "^26.1.0",
        "@types/supertest": "^7.2.0",
        "eslint": "^10.6.0",
        "globals": "^17.7.0",
        "jest": "^30.4.2",
        "source-map-support": "^0.5.21",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.11",
        "ts-loader": "^9.6.2",
        "ts-node": "^10.9.2"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node",
        "moduleNameMapper": {
            "^@/(.*)$": "<rootDir>/$1"
        }
    }
}
